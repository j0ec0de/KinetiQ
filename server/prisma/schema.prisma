// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum Visibility {
  PRIVATE
  PUBLIC
}

// User model

model User {
  id  String @id @default(uuid())
  email String @unique
  username String @unique
  passwordHash String
  role Role @default(USER)
  isVerified Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prompts Prompt[]
  generations Generation[]
  sessions Session[]
  usage Usage?
}

// Prompt model
// Stores what user typed (Eg : "Football", "Tech")

model Prompt {
  id String @id @default(uuid())
  userId String
  title String?
  content String
  visibility Visibility @default(PRIVATE)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  generations Generation[]
  tags PromptTag[]
}

// Generation model
// Stores AI responses linked to prompts.

model Generation {
  id String @id @default(uuid())
  promptId String
  userId String
  modelUsed String
  response Json
  // response stored as JSON -> allows structured output (headings, sections, flashcards, etc)
  tokensUsed Int?
  createdAt DateTime @default(now())

  prompt Prompt @relation(fields: [promptId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

// Tags System (categorization)

model Tag {
  id String @id @default(uuid())
  name String @unique

  prompts PromptTag[]
}

model PromptTag {
  promptId String
  tagId String

  prompt Prompt @relation(fields: [promptId], references: [id])
  tag Tag @relation(fields: [tagId], references: [id])

  @@id([promptId, tagId])
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  refreshToken String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user       User @relation(fields: [userId], references: [id])
}

model Usage {
  id            String  @id @default(uuid())
  userId        String  @unique
  totalPrompts  Int     @default(0)
  totalTokens   Int     @default(0)
  lastActiveAt  DateTime?

  user          User    @relation(fields: [userId], references: [id])
}
